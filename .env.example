# Copie este arquivo para .env.local e preencha com as chaves reais do projeto.
# Nunca commite .env.local nem chaves reais.

# ─── Supabase (cliente público) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase (segredo, somente servidor) ───────────────────────────────────
# Use exclusivamente em código server-side. Nunca exponha no client.
# Necessária quando alguma rota administrativa precisar bypass de RLS
# (ex.: leitura de waitlist_requests pelo backoffice antes do RLS final).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backoffice — autenticação local temporária ─────────────────────────────
# Credenciais únicas e temporárias usadas para proteger /backoffice antes da
# autenticação administrativa definitiva via Supabase Auth.
# Defina valores fortes em .env.local. Nunca commite valores reais.
BACKOFFICE_ADMIN_EMAIL=
BACKOFFICE_ADMIN_PASSWORD=

# Segredo usado para assinar o cookie de sessão administrativa local
# (HMAC). Gere com: `openssl rand -base64 32`.
BACKOFFICE_SESSION_SECRET=

# ─── Emails transacionais (aprovação de conta, avisos administrativos) ──────
# Usado no servidor para enviar email quando uma solicitação é aprovada no
# backoffice. Crie uma API key no Resend e use um remetente/domínio verificado.
RESEND_API_KEY=
TRANSACTIONAL_EMAIL_FROM="Manuscrito <noreply@pulsotech.app.br>"

# URL pública do app usada nos links dos emails. Em desenvolvimento pode ser:
# http://localhost:3000 ou http://localhost:3001, conforme sua porta local.
NEXT_PUBLIC_APP_URL=
